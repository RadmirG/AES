# Copy this file to deploy/.env and replace both password values.
# Docker Compose automatically loads deploy/.env because the top-level
# compose.dev.yaml and compose.prod.yaml files are in this directory.
# Never commit the real deploy/.env file.

AES_POSTGRES_DB=aes
AES_POSTGRES_ADMIN_USER=aes_admin
AES_POSTGRES_ADMIN_PASSWORD=replace-with-a-random-admin-password
AES_POSTGRES_APP_PASSWORD=replace-with-a-different-random-application-password

# The current deployment is reached through localhost or an SSH tunnel over
# plain HTTP. Set this to true only after HTTPS terminates in front of web-ui.
AES_AUTH_COOKIE_SECURE=false
AES_AUTH_SESSION_TTL_SECONDS=43200

# Runtime model selection. Override these for a smaller development setup.
AES_OLLAMA_MODEL=gemma4:31b
AES_OLLAMA_PULL_GROUP=runtime

# Raw FEniCS code generation attempts before a supported deterministic fallback.
DOLFINX_CODE_GENERATION_ATTEMPTS=2
DOLFINX_CODE_REPAIR_ATTEMPTS=2
